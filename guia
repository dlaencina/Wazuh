services:
  redis:
    image: valkey/valkey:7.2
    container_name: misp-redis
    restart: unless-stopped
    healthcheck:
      test: "valkey-cli -e ping || exit 1"
      interval: 10s
      timeout: 3s
      retries: 3
      start_period: 30s
    networks:
      - misp-network

  db:
    image: mariadb:10.11
    container_name: misp-db
    restart: unless-stopped
    environment:
      - MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD}
      - MYSQL_USER=${MYSQL_USER}
      - MYSQL_PASSWORD=${MYSQL_PASSWORD}
      - MYSQL_DATABASE=${MYSQL_DATABASE}
    command: --innodb-buffer-pool-size=512M --innodb-change-buffering=none --innodb-io-capacity=1000 --innodb-io-capacity-max=2000 --innodb-log-file-size=600M --innodb-read-io-threads=16 --innodb-stats-persistent=ON --innodb-write-io-threads=4 --tmp-table-size=512M --max-heap-table-size=512M --innodb-sort-buffer-size=16M --read-buffer-size=4M --read-rnd-buffer-size=32M
    volumes:
      - misp-db-data:/var/lib/mysql
    healthcheck:
      test: "/usr/bin/mariadb --user=$$MYSQL_USER --password=$$MYSQL_PASSWORD --execute \"SHOW DATABASES;\""
      interval: 10s
      timeout: 5s
      retries: 5
      start_period: 60s
    networks:
      - misp-network

  misp-modules:
    image: ghcr.io/misp/misp-docker/misp-modules:latest
    container_name: misp-modules
    restart: unless-stopped
    environment:
      - REDIS_BACKEND=redis
    depends_on:
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-fsSL", "http://0.0.0.0:6666/modules"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 90s
    networks:
      - misp-network

  mail:
    image: ghcr.io/egos-tech/smtp:1.1.3
    container_name: misp-mail
    restart: unless-stopped
    networks:
      - misp-network

  misp-core:
    image: ghcr.io/misp/misp-docker/misp-core:latest
    container_name: misp-core
    restart: unless-stopped
    depends_on:
      redis:
        condition: service_healthy
      db:
        condition: service_healthy
      misp-modules:
        condition: service_healthy
    ports:
      - "8080:80"
      - "8443:443"
    environment:
      - BASE_URL=${BASE_URL}
      - MYSQL_HOST=db
      - MYSQL_USER=${MYSQL_USER}
      - MYSQL_PASSWORD=${MYSQL_PASSWORD}
      - MYSQL_DATABASE=${MYSQL_DATABASE}
      - REDIS_FQDN=redis
      - MISP_MODULES_FQDN=http://misp-modules
      - ADMIN_EMAIL=${ADMIN_EMAIL}
      - ADMIN_PASSWORD=${ADMIN_PASSWORD}
      - ADMIN_KEY=${ADMIN_KEY}
      - ADMIN_ORG=${ADMIN_ORG}
      - GPG_PASSPHRASE=${GPG_PASSPHRASE}
      - SMTP_FQDN=mail
      - DISABLE_IPV6=true
      - ENABLE_DB_SETTINGS=false
      - CRON_USER_ID=1
    volumes:
      - misp-core-config:/var/www/MISP/app/Config
      - misp-core-logs:/var/www/MISP/app/tmp/logs
      - misp-core-files:/var/www


services:
  mail:
    image: ghcr.io/egos-tech/smtp:1.1.3
    restart: always
    environment:
      - "SMARTHOST_ADDRESS=${SMARTHOST_ADDRESS}"
      - "SMARTHOST_PORT=${SMARTHOST_PORT}"
      - "SMARTHOST_USER=${SMARTHOST_USER}"
      - "SMARTHOST_PASSWORD=${SMARTHOST_PASSWORD}"
      - "SMARTHOST_ALIASES=${SMARTHOST_ALIASES}"
      - "TZ=${TZ:-UTC}"

  redis:
    image: valkey/valkey:7.2
    restart: always
    command: |
      sh -c '
      if [ "$${ENABLE_REDIS_EMPTY_PASSWORD:-false}" = "true" ]; then
        exec valkey-server
      else
        exec valkey-server --requirepass "$${REDIS_PASSWORD:-redispassword}"
      fi
      '
    environment:
      - "ENABLE_REDIS_EMPTY_PASSWORD=${ENABLE_REDIS_EMPTY_PASSWORD:-false}"
      - "REDIS_PASSWORD=${REDIS_PASSWORD:-redispassword}"
      - "TZ=${TZ:-UTC}"
    healthcheck:
      test: |
        sh -c '
        if [ "$${ENABLE_REDIS_EMPTY_PASSWORD:-false}" = "true" ]; then
          valkey-cli -p $${REDIS_PORT:-6379} ping | grep -q PONG || exit 1
        else
          valkey-cli -a "$${REDIS_PASSWORD:-redispassword}" -p $${REDIS_PORT:-6379} ping | grep -q PONG || exit 1
        fi
        '
      interval: 2s
      timeout: 1s
      retries: 3
      start_period: 30s
      start_interval: 5s
    volumes:
      - cache_data:/data

  db:
    image: mariadb:10.11
    restart: always
    environment:
      - "MYSQL_USER=${MYSQL_USER:-misp}"
      - "MYSQL_PASSWORD=${MYSQL_PASSWORD:-example}"
      - "MYSQL_ROOT_PASSWORD=${MYSQL_ROOT_PASSWORD:-password}"
      - "MYSQL_DATABASE=${MYSQL_DATABASE:-misp}"
      - "TZ=${TZ:-UTC}"
    command: "--innodb-buffer-pool-size=512M --innodb-change-buffering=none --innodb-io-capacity=1000 --innodb-io-capacity-max=2000 --innodb-log-file-size=600M --innodb-read-io-threads=16 --innodb-stats-persistent=ON --innodb-write-io-threads=4"
    volumes:
      - mysql_data:/var/lib/mysql
    cap_add:
      - SYS_NICE
    healthcheck:
      test: mysqladmin --user=$$MYSQL_USER --password=$$MYSQL_PASSWORD status
      interval: 2s
      timeout: 1s
      retries: 3
      start_period: 60s
      start_interval: 5s

  misp-modules:
    image: ghcr.io/misp/misp-docker/misp-modules:latest
    restart: always
    healthcheck:
      test: "/bin/bash -c '</dev/tcp/localhost/6666'"
      interval: 2s
      timeout: 1s
      retries: 3
      start_period: 60s
      start_interval: 10s
    environment:
      - "TZ=${TZ:-UTC}"

  misp-core:
    image: ghcr.io/misp/misp-docker/misp-core:latest
    restart: always
    cap_add:
      - AUDIT_WRITE
    depends_on:
      redis:
        condition: service_healthy
      db:
        condition: service_healthy
      misp-modules:
        condition: service_healthy
    healthcheck:
      test: curl -ks ${BASE_URL:-https://localhost}/users/heartbeat > /dev/null || exit 1
      interval: 2s
      timeout: 1s
      retries: 3
      start_period: 180s
      start_interval: 30s
    ports:
      - "${CORE_HTTP_PORT:-8080}:80"
      - "${CORE_HTTPS_PORT:-8443}:443"
    volumes:
      - misp_configs:/var/www/MISP/app/Config/
      - misp_logs:/var/www/MISP/app/tmp/logs/
      - misp_files:/var/www/MISP/app/files/
      - misp_ssl:/etc/nginx/certs/
      - misp_gnupg:/var/www/MISP/.gnupg/
    environment:
      - "BASE_URL=${BASE_URL}"
      - "CRON_USER_ID=${CRON_USER_ID:-1}"
      - "DISABLE_IPV6=${DISABLE_IPV6:-true}"
      - "ENABLE_DB_SETTINGS=${ENABLE_DB_SETTINGS:-false}"
      - "ADMIN_EMAIL=${ADMIN_EMAIL}"
      - "ADMIN_PASSWORD=${ADMIN_PASSWORD}"
      - "ADMIN_KEY=${ADMIN_KEY}"
      - "ADMIN_ORG=${ADMIN_ORG}"
      - "GPG_PASSPHRASE=${GPG_PASSPHRASE}"
      - "TZ=${TZ:-UTC}"
      - "MYSQL_HOST=${MYSQL_HOST:-db}"
      - "MYSQL_PORT=${MYSQL_PORT:-3306}"
      - "MYSQL_USER=${MYSQL_USER:-misp}"
      - "MYSQL_PASSWORD=${MYSQL_PASSWORD:-example}"
      - "MYSQL_DATABASE=${MYSQL_DATABASE:-misp}"
      - "REDIS_HOST=${REDIS_HOST:-redis}"
      - "REDIS_PORT=${REDIS_PORT:-6379}"
      - "REDIS_PASSWORD=${REDIS_PASSWORD:-redispassword}"
      - "ENABLE_REDIS_EMPTY_PASSWORD=${ENABLE_REDIS_EMPTY_PASSWORD:-false}"
      - "SMTP_FQDN=${SMTP_FQDN:-mail}"
      - "SMTP_PORT=${SMTP_PORT:-25}"

volumes:
  mysql_data:
  cache_data:
  misp_configs:
  misp_logs:
  misp_files:
  misp_ssl:
